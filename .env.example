# HR Reports Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# Neon Database Configuration
# ===========================================
# Get your connection string from the Neon console:
# https://console.neon.tech/

# Database connection URL (required for ETL scripts and API)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon API Key (for CLI access)
# Create at: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon Project ID (found in project settings)
NEON_PROJECT_ID=your-project-id

# ===========================================
# React App Configuration
# ===========================================
# Set the data source for the React app
# Options: 'json' (default, uses staticData.js) or 'api' (uses Postgres API)
REACT_APP_DATA_SOURCE=json

# API URL for the React app (only used when DATA_SOURCE=api)
# For local development: http://localhost:3001/api
# For production: https://your-vercel-app.vercel.app/api
REACT_APP_API_URL=/api

# ===========================================
# Vercel Configuration
# ===========================================
# These are set automatically by Vercel, but you can override them locally

# Enable verbose logging in development
# VERCEL_ENV=development

# ===========================================
# Optional: Development Settings
# ===========================================

# Enable debug mode for ETL scripts
# DEBUG=true

# Dry run mode (no database writes)
# DRY_RUN=true
