# ==============================================================================
# RAW DATA PROTECTION (Contains PII - NEVER commit)
# ==============================================================================

# Block ALL files in raw/ folders (Excel, CSV from Oracle HCM)
*/raw/**/*
!*/raw/**/.gitkeep

# Additional PII protection patterns
*_pii.*
*_private.*
*_confidential.*
*.bak
*.tmp

# ==============================================================================
# CLEANED DATA (Safe to commit - PII removed)
# ==============================================================================

# Allow cleaned JSON files
!*/cleaned/**/*.json
!*/cleaned/**/*.md

# ==============================================================================
# DOCUMENTATION & TEMPLATES
# ==============================================================================

# Allow README files
!README.md
!*/README.md
!**/README.md

# Allow templates
!templates/*.csv
!templates/*.xlsx
!templates/*.md

# ==============================================================================
# LEGACY PATTERNS (from old structure)
# ==============================================================================

# Keep for backwards compatibility
processed-data/*
!processed-data/.gitkeep
raw-exports/*/*
!raw-exports/*/.gitkeep