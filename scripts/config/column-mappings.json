  "_metadata": {
    "total_fields": 42,
    "ambiguous_aliases": {
      "date": {
        "conflict": "Used by both mobility (effective_date) and exit-surveys (survey_date)",
        "mobility_context": "row.effective_date || row.effectiveDate || row.date -> mapped to effective_date",
        "exit_survey_context": "row.survey_date || row.surveyDate || row.date -> mapped to survey_date",
        "resolution": "Context-dependent. The column-resolver must know which script/domain is active to resolve 'date' correctly."
      },
      "reason": {
        "conflict": "Used as both reason_code fallback and action categorization input in mobility script",
        "note": "row.reason_code || row.reasonCode || row.reason for reason_code field, AND row.reason directly for categorizeActionType()"
      }
    },
    "scripts_covered": [
      "workforce-to-postgres.js",
      "terminations-to-postgres.js",
      "demographics-to-postgres.js",
      "mobility-to-postgres.js",
      "exit-surveys-to-postgres.js",
      "turnover-rates-to-postgres.js",
      "turnover-metrics-to-postgres.js",
      "recruiting-metrics-to-postgres.js",
      "state-residence-to-postgres.js"
    ],
    "notes": [
      "turnover-metrics and recruiting-metrics scripts read from structured Excel sheets with fixed column names (no alias chains needed).",
      "state-residence script reads JSON with state code keys (no column aliasing needed).",
      "Assignment category alias chains differ slightly between workforce (5 aliases) and terminations (3 aliases).",
      "Demographics script uses 'Assignment Category Code' and 'assignmentCategoryCode' (subset of workforce aliases)."
    ]
