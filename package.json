    "clean:workforce": "node scripts/clean-workforce-data.js",
    "clean:terminations": "node scripts/clean-terminations-data.js",
    "clean:exit-surveys": "node scripts/clean-exit-surveys-data.js",
    "import:workforce": "node scripts/data-import.js workforce",
    "import:terminations": "node scripts/data-import.js terminations",
    "import:exit-surveys": "node scripts/data-import.js exit-surveys",
    "import:wizard": "node scripts/data-wizard-interactive.js",
    "validate:all": "node scripts/validate-all-sources.js",
    "db:migrate": "node scripts/etl/migrate.js",
    "db:migrate:fresh": "node scripts/etl/migrate.js --fresh",
    "db:seed": "node scripts/etl/migrate.js --seed",
    "etl:workforce": "node scripts/etl/workforce-to-postgres.js",
    "etl:terminations": "node scripts/etl/terminations-to-postgres.js",
    "etl:exit-surveys": "node scripts/etl/exit-surveys-to-postgres.js",
    "etl:mobility": "node scripts/etl/mobility-to-postgres.js",
    "etl:demographics": "node scripts/etl/demographics-to-postgres.js",
    "etl:demographics:export": "node scripts/etl/export-demographics-json.js",
    "etl:turnover": "node scripts/etl/turnover-metrics-to-postgres.js",
    "etl:turnover:generate": "node scripts/generate-turnover-excel-template.js",
    "etl:sample-data": "node scripts/etl/load-sample-data.js",
    "ci:local": "npm ci && npm run build && npm test -- --coverage --watchAll=false",
    "ci:quick": "npm run build && npm test -- --watchAll=false",
    "ci:audit": "npm audit --audit-level=high || true",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
