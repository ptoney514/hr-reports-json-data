# Runtime data

# Data import pipeline rules
# IGNORE: All raw data files (too large, can be re-downloaded)
source-metrics/**/raw/**/*
source-metrics/*/fy*/
source-metrics/*/FY*/

# KEEP: Cleaned CSV data files (needed for cross-machine work)
# These are essential transformed data that should be in Git
!source-metrics/**/cleaned/**/*.csv
!source-metrics/**/cleaned_data/**/*.csv

# IGNORE: Large JSON summaries (can be regenerated from CSV)
source-metrics/**/cleaned/**/*_summary.json
source-metrics/**/cleaned/**/*_cleaned.json
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

