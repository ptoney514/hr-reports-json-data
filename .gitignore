# Runtime data

# Data import pipeline rules
# IGNORE: All raw data files (too large, can be re-downloaded)
source-metrics/**/raw/**/*
source-metrics/*/fy*/
source-metrics/*/FY*/

# Sensitive HR data files - NEVER track
*.xlsx
*.xls
*.xlsm
~$*.xlsx
source-metrics/**/cleaned/**/*.csv
source-metrics/**/cleaned/**/*.json
public/source-metrics/
sample_data/
test-*.csv
EXIT_SURVEY_CONFIDENTIAL_SOURCES.md
pids
*.pid
*.seed
*.pid.lock

